# Source this from the repo root:
#   set -a; source examples/webhook_reflex_then_planning/.env.example; set +a

REFLEXOR_PROFILE=dev
REFLEXOR_DRY_RUN=true

REFLEXOR_DATABASE_URL=sqlite+aiosqlite:///./examples/webhook_reflex_then_planning/reflexor.db
REFLEXOR_WORKSPACE_ROOT=./examples/webhook_reflex_then_planning

# Allow only safe scopes for this demo.
REFLEXOR_ENABLED_SCOPES=fs.read
REFLEXOR_APPROVAL_REQUIRED_SCOPES=

# Allowlists stay empty unless you explicitly set them.
REFLEXOR_HTTP_ALLOWED_DOMAINS=
REFLEXOR_WEBHOOK_ALLOWED_TARGETS=

# Planning trigger knobs (event-driven debounce is used; tick interval is large here).
REFLEXOR_PLANNER_DEBOUNCE_S=0.25
REFLEXOR_PLANNER_INTERVAL_S=60

