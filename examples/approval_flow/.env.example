# Source this from the repo root:
#   set -a; source examples/approval_flow/.env.example; set +a

REFLEXOR_PROFILE=dev
REFLEXOR_DRY_RUN=true

REFLEXOR_DATABASE_URL=sqlite+aiosqlite:///./examples/approval_flow/reflexor.db
REFLEXOR_WORKSPACE_ROOT=./examples/approval_flow

REFLEXOR_ENABLED_SCOPES=fs.write
REFLEXOR_APPROVAL_REQUIRED_SCOPES=fs.write

REFLEXOR_HTTP_ALLOWED_DOMAINS=
REFLEXOR_WEBHOOK_ALLOWED_TARGETS=

