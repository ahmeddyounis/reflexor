# Copy to `.env` for local development.
# NOTE: Reflexor does not auto-load `.env` files yet. If you want to load one, call
# `reflexor.config.load_env_file()` (requires `python-dotenv`).

# Profile: dev | prod
REFLEXOR_PROFILE=dev

# Safety defaults
REFLEXOR_DRY_RUN=true

# Admin API authentication
# If REFLEXOR_ADMIN_API_KEY is unset:
# - admin endpoints are allowed in dev
# - admin endpoints are denied in prod
# In prod deployments, set a strong value.
# REFLEXOR_ADMIN_API_KEY=change-me
REFLEXOR_EVENTS_REQUIRE_ADMIN=false

# Prod safety latch:
# In prod, REFLEXOR_DRY_RUN=false requires REFLEXOR_ALLOW_SIDE_EFFECTS_IN_PROD=true
REFLEXOR_ALLOW_SIDE_EFFECTS_IN_PROD=false

# Wildcards are disabled by default for allowlists
REFLEXOR_ALLOW_WILDCARDS=false

# Permission scopes (deny-by-default)
REFLEXOR_ENABLED_SCOPES=[]
# Example:
# REFLEXOR_ENABLED_SCOPES=["fs.read","net.http"]

# Scopes that should require human approval (enforced by policy; must be subset of enabled)
REFLEXOR_APPROVAL_REQUIRED_SCOPES=[]
# Example:
# REFLEXOR_APPROVAL_REQUIRED_SCOPES=["fs.write"]

# HTTP domain allowlist (hostnames only; no scheme/path/port)
REFLEXOR_HTTP_ALLOWED_DOMAINS=[]
# Examples:
# REFLEXOR_HTTP_ALLOWED_DOMAINS=["example.com","api.example.com"]
# REFLEXOR_HTTP_ALLOWED_DOMAINS=["*.example.com"]  # requires REFLEXOR_ALLOW_WILDCARDS=true

# Webhook target allowlist (http(s) URLs only; no credentials)
REFLEXOR_WEBHOOK_ALLOWED_TARGETS=[]
# Example:
# REFLEXOR_WEBHOOK_ALLOWED_TARGETS=["https://hooks.example.com/path"]

# Workspace root (relative paths resolve against the process working directory)
REFLEXOR_WORKSPACE_ROOT=.

# Database defaults
REFLEXOR_DATABASE_URL=sqlite+aiosqlite:///./reflexor.db
REFLEXOR_DB_ECHO=false
# Pool tuning (ignored for SQLite; useful for Postgres later)
# REFLEXOR_DB_POOL_SIZE=5
# REFLEXOR_DB_MAX_OVERFLOW=10
# REFLEXOR_DB_POOL_TIMEOUT_S=30
# REFLEXOR_DB_POOL_PRE_PING=true

# Queue defaults
REFLEXOR_QUEUE_BACKEND=inmemory
REFLEXOR_QUEUE_VISIBILITY_TIMEOUT_S=60
# Redis Streams queue (when REFLEXOR_QUEUE_BACKEND=redis_streams)
# REFLEXOR_REDIS_URL=redis://localhost:6379/0
# REFLEXOR_REDIS_STREAM_KEY=reflexor:tasks
# REFLEXOR_REDIS_CONSUMER_GROUP=reflexor
# REFLEXOR_REDIS_CONSUMER_NAME=reflexor-my-host-1
# REFLEXOR_REDIS_STREAM_MAXLEN=10000
# REFLEXOR_REDIS_CLAIM_BATCH_SIZE=50
# REFLEXOR_REDIS_PROMOTE_BATCH_SIZE=50
# REFLEXOR_REDIS_VISIBILITY_TIMEOUT_MS=60000
# REFLEXOR_REDIS_DELAYED_ZSET_KEY=reflexor:tasks:delayed

# Executor defaults
REFLEXOR_EXECUTOR_MAX_CONCURRENCY=50
REFLEXOR_EXECUTOR_PER_TOOL_CONCURRENCY={}
# Example (JSON object):
# REFLEXOR_EXECUTOR_PER_TOOL_CONCURRENCY={"echo":5}
# Example (comma-separated pairs):
# REFLEXOR_EXECUTOR_PER_TOOL_CONCURRENCY=echo=5,other_tool=2
REFLEXOR_EXECUTOR_DEFAULT_TIMEOUT_S=60
REFLEXOR_EXECUTOR_VISIBILITY_TIMEOUT_S=60
REFLEXOR_EXECUTOR_RETRY_BASE_DELAY_S=1
REFLEXOR_EXECUTOR_RETRY_MAX_DELAY_S=60
REFLEXOR_EXECUTOR_RETRY_JITTER=0

# Orchestrator defaults
REFLEXOR_PLANNER_INTERVAL_S=60
REFLEXOR_PLANNER_DEBOUNCE_S=2
REFLEXOR_EVENT_BACKLOG_MAX=200
REFLEXOR_MAX_EVENTS_PER_PLANNING_CYCLE=50
REFLEXOR_MAX_TASKS_PER_RUN=50
REFLEXOR_MAX_TOOL_CALLS_PER_RUN=50
REFLEXOR_MAX_RUN_WALL_TIME_S=30

# Size limits (bytes)
REFLEXOR_MAX_EVENT_PAYLOAD_BYTES=64000
REFLEXOR_MAX_TOOL_OUTPUT_BYTES=64000
REFLEXOR_MAX_RUN_PACKET_BYTES=512000
