# Copy to `.env` for local development.
# NOTE: Reflexor does not auto-load `.env` files yet. If you want to load one, call
# `reflexor.config.load_env_file()` (requires `python-dotenv`).

# Profile: dev | prod
REFLEXOR_PROFILE=dev

# Safety defaults
REFLEXOR_DRY_RUN=true

# Prod safety latch:
# In prod, REFLEXOR_DRY_RUN=false requires REFLEXOR_ALLOW_SIDE_EFFECTS_IN_PROD=true
REFLEXOR_ALLOW_SIDE_EFFECTS_IN_PROD=false

# Wildcards are disabled by default for allowlists
REFLEXOR_ALLOW_WILDCARDS=false

# Permission scopes (deny-by-default)
REFLEXOR_ENABLED_SCOPES=[]
# Example:
# REFLEXOR_ENABLED_SCOPES=["fs.read","net.http"]

# Scopes that should require human approval (enforced by policy; must be subset of enabled)
REFLEXOR_APPROVAL_REQUIRED_SCOPES=[]
# Example:
# REFLEXOR_APPROVAL_REQUIRED_SCOPES=["fs.write"]

# HTTP domain allowlist (hostnames only; no scheme/path/port)
REFLEXOR_HTTP_ALLOWED_DOMAINS=[]
# Examples:
# REFLEXOR_HTTP_ALLOWED_DOMAINS=["example.com","api.example.com"]
# REFLEXOR_HTTP_ALLOWED_DOMAINS=["*.example.com"]  # requires REFLEXOR_ALLOW_WILDCARDS=true

# Webhook target allowlist (http(s) URLs only; no credentials)
REFLEXOR_WEBHOOK_ALLOWED_TARGETS=[]
# Example:
# REFLEXOR_WEBHOOK_ALLOWED_TARGETS=["https://hooks.example.com/path"]

# Workspace root (relative paths resolve against the process working directory)
REFLEXOR_WORKSPACE_ROOT=.

# Size limits (bytes)
REFLEXOR_MAX_EVENT_PAYLOAD_BYTES=64000
REFLEXOR_MAX_TOOL_OUTPUT_BYTES=64000
REFLEXOR_MAX_RUN_PACKET_BYTES=512000
